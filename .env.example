# Copy to .env and adjust. Do not commit .env (secrets).

# --- Database ---
# Docker Compose: DATABASE_URL is set inside docker-compose.yml to internal Postgres+pgvector
# (not exposed on the host). Values here are ignored for that key when using the shipped compose file.
#
# Native uvicorn (no Docker): leave empty for SQLite (default), or set for Postgres/Supabase:
# Leave empty or unset for SQLite (default). For Supabase/Postgres, set to the
# connection URI from Project Settings → Database → Connection string (URI).
# Format: postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# (This is not the project URL https://xxx.supabase.co)
# DATABASE_URL=

# SQLite path (used only when DATABASE_URL is empty)
# DATABASE_PATH=ledgerly.db

# --- Embeddings (Ollama) ---
EMBED_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
# Seconds per /api/embed request (large PDFs may need 120+)
EMBED_TIMEOUT=120
EMBED_MAX_ATTEMPTS=3
# Strings per embed request; smaller = lighter CPU per call, more round trips. 0 = single request for all chunks (legacy).
EMBED_BATCH_SIZE=32
EMBED_DIM=768
# Optional pause (seconds) after each embed batch; spreads CPU load.
EMBED_INTER_BATCH_SLEEP_SEC=0
# SQLite /ask retrieval: max rows scored in Python (0 = no cap). Postgres uses pgvector.
# SQLITE_RETRIEVAL_MAX_EMBEDDINGS=5000
# Background ingest queue: pause between completed jobs (seconds).
INGEST_QUEUE_INTER_JOB_SLEEP_SEC=3
# Suggested UI poll interval for GET /ingest/jobs (seconds). static/index.html polls every 15s for multi-file jobs.
INGEST_UI_POLL_INTERVAL_SEC=15

# --- Originals vault (optional local backup of uploaded files, watched incoming/) ---
# If set, this path wins over UI-saved settings. PDF/image uploads can be copied under originals/;
# files dropped in {vault}/incoming/ stay in place (any subfolders; watcher is recursive).
# Use an absolute path on the server host (e.g. /Users/you/Documents/LedgerlyVault).
# Docker: mount a host directory and set this to the in-container path (e.g. /data/vault).
# LEDGERLY_ORIGINALS_VAULT=
# When LEDGERLY_ORIGINALS_VAULT is set, VAULT_INCOMING_MODE below is used. When unset, use the Ingest tab
# "Watched library" UI — settings are stored in .ledgerly/vault_settings.json (gitignored).
# Watch folder {vault}/incoming/ (recursive): off | watch_auto | watch_review (move to pending/, then POST /vault/pending/ingest)
# VAULT_INCOMING_MODE=off
# Allow PUT /vault/settings from non-loopback (default false; localhost only).
# If false, opening the UI via LAN IP or hostname makes Save look broken until you use
# http://127.0.0.1:<port> or set this to true (only if you trust every client on that network).
# Native folder picker (Ingest → Watched library) is always localhost-only and unavailable in headless Docker.
# ALLOW_REMOTE_VAULT_SETTINGS=false
# Seconds to wait for file size to stabilize after a drop (web writes not in use here but safe for slow copies)
# VAULT_DEBOUNCE_SEC=2
# Skip a second enqueue/move for the same incoming-relative path within this window (same path replacement bursts). 0 = off.
# VAULT_PATH_COOLDOWN_SEC=0
# With vault enabled, also save a UTF-8 .txt snapshot for pasted-text ingest (POST /ingest).
# VAULT_SAVE_TEXT_INGEST=true
# If true, ingest fails when the vault directory exists but writing the copy fails.
# VAULT_INGEST_REQUIRE_WRITE=false

# Allow POST /documents/{id}/reveal-source when the HTTP client is not loopback (e.g. remote LAN).
# Default: only localhost may open local files. Set true only if you understand the risk.
# ALLOW_LOCAL_FILE_REVEAL=false

# PDF ingest (scanned / image-like PDFs): native text extraction, optional Tesseract OCR, vision fallback.
# Requires tesseract binary on PATH for OCR (Dockerfile installs tesseract-ocr).
# PDF_WEAK_TEXT_MAX_CHARS_PER_PAGE=40
# PDF_VISION_MAX_PAGES=20
# PDF_VISION_PAGE_THRESHOLD=8
# PDF_OCR_ENABLED=true
# PDF_OCR_MIN_CHARS=10

# Learning UI: bullet facts per document via local LLM during ingest (adds latency).
# INGEST_FACTS_ENABLED=true
# Max characters of document text sent to the model (first portion only for long PDFs).
# INGEST_FACTS_MAX_CHARS=14000

# --- Maturity reminders (Home dashboard / decision triggers) ---
# Flag CDs and obligations due within this many days (default 30; try 60–90 for earlier in-app reminders).
# MATURITY_DAYS_AHEAD=30
# OBLIGATION_DAYS_AHEAD=30

# --- LLM (Ollama) ---
LLM_BASE_URL=http://localhost:11434
# Default full-size model. With LEDGERLY_PROFILE=portable, omit LLM_MODEL (uses qwen2.5:3b).
LLM_MODEL=qwen3:8b
# LEDGERLY_PROFILE=portable
# Vision: omit LLAVA_MODEL when portable (uses moondream). See setup_and_testing.md.
LLAVA_MODEL=llava:7b
LLM_TIMEOUT_SECONDS=60
LLM_MAX_ATTEMPTS=3
LLM_RATE_LIMIT_SECONDS=60
LLM_TOKEN_LIMIT=10
# Pause (seconds) before classifier/finance-intent LLM calls in Ask; spreads CPU load (try 1–3 on laptops).
# LLM_INTER_CALL_SLEEP_SEC=2
# Max concurrent Ollama HTTP ops (embed + chat + vision). Use 1 on laptops.
# OLLAMA_MAX_CONCURRENT=1
# llama.cpp thread cap for the Ollama *server* (Docker Compose passes this to the ollama service).
# When unset, start.sh / start-ledgerly.sh auto-set from CPU count (conservative: ~half cores, cap 8).
# Lower = less CPU heat and fan noise; higher = faster inference. Native Ollama: set on the host instead.
# OLLAMA_NUM_THREADS=4
# Preload Ollama models when opening Ask or Ingest tabs (background; reduces first-request cold start).
# OLLAMA_WARMUP_ENABLED=true
# OLLAMA_WARMUP_KEEP_ALIVE=15m
# OLLAMA_WARMUP_SESSION_SEC=900
# Background ask queue wait hint (seconds) and pacing between jobs.
# ASK_QUEUE_ESTIMATED_WAIT_SEC=600
# ASK_QUEUE_INTER_JOB_SLEEP_SEC=5

# --- OpenAI (general path only: CD advice, POST /ask/general; no PII in prompts) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=60
# OPENAI_MAX_ATTEMPTS=3

# --- Finance MCP (Ask: quotes + compound interest) ---
# Optional: Finnhub key for live stock quotes. Passed through Docker Compose to the finance-mcp service.
# FINNHUB_API_KEY=
# If you run the main app on the host (not Docker) but finance-mcp is in Docker on port 8001:
# FINANCE_TOOLS_BASE_URL=http://127.0.0.1:8001
# With Docker Compose as shipped, the app container uses http://finance-mcp:8000 automatically (no need to set this).

# --- Google Drive (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Re-ranker (two-stage retrieval; optional) ---
# When true, first stage retrieves more candidates, then a local cross-encoder re-ranks to top_k.
# RERANK_ENABLED=false
# RERANK_INITIAL_K_MULTIPLIER=3
# RERANK_INITIAL_K_MAX=50
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Remote log (Option B: Supabase Edge Function). When set, errors are POSTed (no PII).
# Independent of DATABASE_URL: you can use local SQLite/Postgres for app data and still point
# these at a hosted Supabase project for dashboard logs. See setup_and_testing.md.
# REMOTE_LOG_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/ingest-remote-log
# REMOTE_LOG_SECRET=  (optional; set in Supabase secrets as REMOTE_LOG_SECRET)
# REMOTE_LOG_INSTANCE_ID=  (optional; e.g. UUID to distinguish this instance)
# SUPABASE_ANON_KEY=  (optional; anon key from Project Settings → API; avoids 401 when calling Edge Function)

# --- Observability (optional Docker Compose profile) ---
# Start stack + metrics + log shipping:  docker compose --profile observability up -d
# Prometheus → http://localhost:9090  Grafana → http://localhost:3000  Loki → http://localhost:3100
# Exposes GET /metrics on the app when true; domain counters/histograms only register when true.
# METRICS_ENABLED=true
# One JSON object per line for ask_trace events (best for Grafana Loki | json). Other logs keep the default format.
# LOG_JSON=true

# Structured extraction during ingest (default on; uses regex fast-path then local LLM)
# INGEST_STRUCTURED_ENABLED=true
# INGEST_STRUCTURED_MAX_CHARS=14000

# Auto-create positions/obligations from ingest extraction (default on)
INGEST_AUTO_TRACK_ENABLED=true
RECENT_TRACK_DAYS=7
RECENT_TRACK_LIMIT=10
